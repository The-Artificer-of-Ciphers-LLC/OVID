# ============================================================
# OVID Development / Standalone Environment Variables
# ============================================================
# For local development or self-hosted standalone instances.
# Copy this file to .env and fill in values before running:
#   docker-compose up
#
# For production deployment (oviddb.org), use .env.production.example instead.
# ============================================================

# Database
OVID_DB_NAME=ovid
OVID_DB_USER=ovid
OVID_DB_PASSWORD=change_me_in_production

# API
OVID_SECRET_KEY=change_me_to_a_long_random_string
OVID_API_URL=http://localhost:8000
LOG_LEVEL=info

# Deployment environment: development | production
# REQUIRED — the API refuses to boot (raises at import time) if this is unset or
# set to any other value. In production the IndieAuth localhost bypass is
# disabled by construction (ALLOW_LOCALHOST_BYPASS is False), so a dev-only
# bypass can never be reachable in a production deployment.
#
# BREAKING CHANGE: existing self-hosted instances MUST set OVID_ENV on upgrade;
# there is no default. Use `development` for local/self-hosted, `production` for
# the canonical oviddb.org deployment.
OVID_ENV=development

# ---------------------------------------------------------------------------
# Rate-limit backend (Redis) — multi-worker deployments only
# ---------------------------------------------------------------------------
# The API rate limiter (slowapi) picks its store from REDIS_URL:
#   set   -> shared Redis store; counters are correct across gunicorn workers
#   unset -> per-worker in-memory ("memory://") counters
#
# Single-worker deployments (the plain `docker compose up` dev/mirror/self-host
# stack) DO NOT need Redis — memory:// is already correct there, so leave both
# of these unset. Redis is only required for the multi-worker (gunicorn -w N,
# N>1) prod/test stacks, where each worker would otherwise keep its own counter
# and inflate every limit up to Nx. The prod/test compose files already set
# these for you (redis service + REDIS_URL=redis://redis:6379/0, OVID_WORKERS=4).
#
# OVID_WORKERS must match the gunicorn `-w` worker count. As a safety guard, if
# OVID_WORKERS>1 and REDIS_URL is unset the API refuses to boot (fail-fast)
# rather than silently inflating its rate limits.
# REDIS_URL=redis://redis:6379/0
# OVID_WORKERS=1

# GitHub OAuth (optional — required for GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple Sign-In (optional — required for Apple login)
# All four must be set for Apple Sign-In to be active.
# APPLE_PRIVATE_KEY is the ES256 PEM private key, base64-encoded for env-var safety.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Google OAuth (optional — required for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mastodon OAuth (optional — required for Mastodon login)
# No credentials needed — uses per-instance dynamic registration


# IndieAuth (optional — DISABLED by default; NOT one of the four headline
# providers). IndieAuth routes (/v1/auth/indieauth/*) register only when this
# is set to a truthy value (1, true, or yes); left empty they return 404 and the
# default auth surface stays limited to GitHub / Apple / Google / Mastodon.
OVID_ENABLE_INDIEAUTH=
# CORS allowed origins (comma-separated, defaults to http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Node mode: standalone | mirror | canonical
# standalone = local-only, no sync (good for dev and self-hosted instances)
# mirror     = syncs from the canonical server periodically (good for home NAS)
# canonical  = the main oviddb.org server (only used by project maintainers)
OVID_MODE=standalone

# ---------------------------------------------------------------------------
# Mirror mode setup
# ---------------------------------------------------------------------------
# To run as a read-only mirror syncing from the canonical server:
#   1. Set OVID_MODE=mirror
#   2. Set SYNC_SOURCE_URL to the canonical API (default works for oviddb.org)
#   3. Run: docker compose --profile mirror up -d
#
# The mirror profile starts a sync sidecar that polls the canonical server
# for changes. All write endpoints (POST/PUT/DELETE/PATCH) return 405 while
# in mirror mode. Check sync progress:
#   docker compose logs sync
#
# Sync source (only used in mirror mode)
# Points to the canonical OVID API for pulling sync diffs.
SYNC_SOURCE_URL=https://api.oviddb.org

# How often to pull diffs from canonical (minutes)
SYNC_INTERVAL_MINUTES=60

# ---------------------------------------------------------------------------
# Reverse proxy trust (production behind nginx/Cloudflare — docker-compose.prod.yml)
# ---------------------------------------------------------------------------
# Comma-separated trusted reverse-proxy IP(s) whose X-Forwarded-For is honored
# so the app sees real client IPs (rate limiting + anti-Sybil IP-diversity).
# Set to your reverse-proxy host IP in production; default 127.0.0.1.
#
# Only takes effect for the production gunicorn command (docker-compose.prod.yml),
# which passes this as gunicorn's --forwarded-allow-ips. Requests whose direct
# TCP peer is NOT in this list have their X-Forwarded-For/X-Real-IP ignored, so
# leaving this unset/default is always safe — it just means client IPs seen by
# the app will be the proxy's own IP instead of the real visitor, degrading (not
# breaking) rate limiting and anti-Sybil IP-diversity. Not used by the plain
# `docker compose up` dev/mirror stack (no gunicorn, no proxy hop there).
OVID_FORWARDED_ALLOW_IPS=127.0.0.1

# ---------------------------------------------------------------------------
# Anti-Sybil confirmation signal (optional)
# ---------------------------------------------------------------------------
# Salt used to compute a salted HMAC-SHA256 hash of the confirming user's IP
# subnet (/24 for IPv4, /48 for IPv6) as a soft anti-Sybil independence signal
# on disc CONFIRMATION (a second contributor re-submitting an existing disc).
# The raw IP is never stored — only this salted, truncated hash, retained for
# ~90 days. See docs/privacy.md for the full data-category disclosure.
#
# OPTIONAL / fail-open: unlike OVID_SECRET_KEY, this is NOT required to boot.
# If unset, the IP-diversity signal is simply absent for this deployment —
# confirmations still work via the other anti-Sybil signals (account age +
# per-account cooldown), just without the IP-diversity component.
OVID_IP_HASH_SALT=
