# ============================================================
# OVID Development / Standalone Environment Variables
# ============================================================
# For local development or self-hosted standalone instances.
# Copy this file to .env and fill in values before running:
#   docker-compose up
#
# For production deployment (oviddb.org), use .env.production.example instead.
# ============================================================

# Database
OVID_DB_NAME=ovid
OVID_DB_USER=ovid
OVID_DB_PASSWORD=change_me_in_production

# API
OVID_SECRET_KEY=change_me_to_a_long_random_string
OVID_API_URL=http://localhost:8000
LOG_LEVEL=info

# GitHub OAuth (optional — required for GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple Sign-In (optional — required for Apple login)
# All four must be set for Apple Sign-In to be active.
# APPLE_PRIVATE_KEY is the ES256 PEM private key, base64-encoded for env-var safety.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Google OAuth (optional — required for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mastodon OAuth (optional — required for Mastodon login)
# No credentials needed — uses per-instance dynamic registration

# CORS allowed origins (comma-separated, defaults to http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Node mode: standalone | mirror | canonical
# standalone = local-only, no sync (good for dev and self-hosted instances)
# mirror     = syncs from the canonical server periodically (good for home NAS)
# canonical  = the main oviddb.org server (only used by project maintainers)
OVID_MODE=standalone

# ---------------------------------------------------------------------------
# Mirror mode setup
# ---------------------------------------------------------------------------
# To run as a read-only mirror syncing from the canonical server:
#   1. Set OVID_MODE=mirror
#   2. Set SYNC_SOURCE_URL to the canonical API (default works for oviddb.org)
#   3. Run: docker compose --profile mirror up -d
#
# The mirror profile starts a sync sidecar that polls the canonical server
# for changes. All write endpoints (POST/PUT/DELETE/PATCH) return 405 while
# in mirror mode. Check sync progress:
#   docker compose logs sync
#
# Sync source (only used in mirror mode)
# Points to the canonical OVID API for pulling sync diffs.
SYNC_SOURCE_URL=https://api.oviddb.org

# How often to pull diffs from canonical (minutes)
SYNC_INTERVAL_MINUTES=60
