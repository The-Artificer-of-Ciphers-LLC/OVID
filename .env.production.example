# ============================================================
# OVID Production Environment Variables
# ============================================================
# For the canonical oviddb.org deployment.
# Copy this file to .env and fill in ALL values before running:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# For local development, use .env.example instead.
# ============================================================

# --- Database ---
OVID_DB_NAME=ovid
OVID_DB_USER=ovid
OVID_DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- API Secrets ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
OVID_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
OVID_API_URL=https://api.oviddb.org
LOG_LEVEL=info

# --- Redis / Valkey ---
# Required in production for shared rate limiting, sessions, and token blacklist.
REDIS_URL=redis://valkey:6379/0

# --- Session Secret ---
# Separate from JWT secret. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET_KEY=CHANGE_ME_TO_A_DIFFERENT_RANDOM_STRING

# --- Cookie ---
# Cookie domain for auth cookies (include leading dot for subdomain support)
COOKIE_DOMAIN=.oviddb.org
ALLOWED_ORIGINS=https://oviddb.org
CORS_ORIGINS=https://oviddb.org

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Apple Sign-In ---
# All four must be set for Apple Sign-In to be active.
# APPLE_PRIVATE_KEY is the ES256 PEM private key, base64-encoded for env-var safety.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Node mode ---
OVID_MODE=canonical
